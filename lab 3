df = pd.read_csv("ITA105_Lab_3_Finance.csv")


df.plot(kind='box')
plt.title("Boxplot - Finance")
plt.show()

plt.scatter(df.iloc[:,0], df.iloc[:,1])
plt.xlabel("Revenue")
plt.ylabel("Profit")
plt.title("Before Scaling")
plt.show()


df_minmax = pd.DataFrame(minmax.fit_transform(df), columns=df.columns)
df_zscore = pd.DataFrame(zscore.fit_transform(df), columns=df.columns)

plt.scatter(df_minmax.iloc[:,0], df_minmax.iloc[:,1])
plt.title("Min-Max Scaling")
plt.show()

plt.scatter(df_zscore.iloc[:,0], df_zscore.iloc[:,1])
plt.title("Z-Score Scaling")
plt.show()
